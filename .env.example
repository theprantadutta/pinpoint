# IMPORTANT: Do NOT put AI provider keys (Gemini/OpenAI) in this file.
# It is bundled into the APK as an asset and is trivially extractable, so any
# secret placed here is effectively public. AI provider keys belong in the
# BACKEND env; the app should call a backend proxy endpoint, never the provider
# directly.

# Firebase Authentication
# Web Client ID from Firebase Console (for Google Sign-In serverClientId parameter)
GOOGLE_WEB_CLIENT_ID=your_google_web_client_id_here

# API Configuration
API_BASE_URL_DEV=http://localhost:8645
API_BASE_URL_PROD=https://your-api-domain.com
