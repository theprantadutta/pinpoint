<?xml version="1.0" encoding="utf-8"?>
<!--
  Phase 1 / F2: the local database is encrypted at rest, but we additionally
  exclude all app data from Android 12+ cloud backup and device-to-device
  transfer so the DB file (and its key) can never leave the device via backup.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </device-transfer>
</data-extraction-rules>
